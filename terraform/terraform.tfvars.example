# Copy this to dev.tfvars (or prod.tfvars) and fill in the placeholders.
# dev.tfvars is gitignored; this example is committed as the canonical
# template. Auth still requires `aws configure` having been run.

region = "us-east-1"
prefix = "havoc"

# IAM principal that gets cluster-admin via the EKS Access Entry. This
# is the same user that runs `terraform apply` and `aws eks
# update-kubeconfig` from the laptop. Find your ARN with:
#   aws sts get-caller-identity --query Arn --output text
admin_iam_user_arn = "arn:aws:iam::<ACCOUNT_ID>:user/<IAM_USER>"

# Single-AZ data plane — both subnets exist only to satisfy EKS / RDS
# minimums; workloads run in azs[0] only.
azs                 = ["us-east-1a", "us-east-1b"]
public_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24"]

# Smallest viable dev sizing. See variables.tf for the rationale on
# each default. t3.medium is sometimes blocked on new AWS accounts;
# t3.small is the next tier down with enough RAM for kube-system +
# Strimzi + Havoc.
eks_node_instance_type = "t3.small"
eks_node_count         = 2
eks_node_disk_size     = 20

rds_instance_class    = "db.t3.micro"
rds_allocated_storage = 20

redis_node_type = "cache.t3.micro"
